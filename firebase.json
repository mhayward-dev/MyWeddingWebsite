{
  "hosting": {
    "public": "src/site",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/rsvp",
        "function": {
          "functionId": "submitRsvp",
          "region": "europe-west1"
        }
      },
      {
        "source": "/api/auth",
        "function": {
          "functionId": "checkPassword",
          "region": "europe-west1"
        }
      },
      {
        "source": "/login",
        "destination": "/login.html"
      },
      {
        "source": "/rsvp",
        "destination": "/rsvp.html"
      }
    ]
  },
  "functions": {
    "source": "src/functions",
    "codebase": "default",
    "runtime": "nodejs22"
  }
}
